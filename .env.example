# carwork2 环境变量示例。部署时复制为 .env 并填入真实值（.env 不进仓库）。

# Agent —— 真实 DeepSeek（文本对话 + function calling）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Agent —— 视觉识损（多模态，可选；留空则 assess_damage 返回未配置提示）
MAAS_API_KEY=
MAAS_BASE_URL=https://token.bayesdl.com/api/maas/v1
MAAS_VL_MODEL=qwen3-vl-plus
